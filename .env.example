# ================================
# INISTNT — Environment Variables
# ================================

NODE_ENV=development

# ─── PORTS ───
API_GATEWAY_PORT=4000
MATCHING_ENGINE_PORT=4001
NOTIFICATION_SERVICE_PORT=4002
WORKER_VERIFICATION_PORT=4003

# ─── DATABASE (Supabase) ───
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── CACHE (Valkey) ───
REDIS_URL=redis://localhost:6379

# ─── JWT ───
JWT_ACCESS_SECRET=change-this-secret
JWT_REFRESH_SECRET=change-this-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── MSG91 (SMS/OTP) ───
MSG91_API_KEY=
MSG91_SENDER_ID=INSNT

# ─── RAZORPAY ───
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── GOOGLE MAPS ───
GOOGLE_MAPS_API_KEY=

# ─── FIREBASE (Push Notifications) ───
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── CLOUDFLARE R2 (Images) ───
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=inistnt-media

# ─── RESEND (Email) ───
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@inistnt.in

# ─── INTERNAL SERVICES ───
MATCHING_ENGINE_URL=http://localhost:4001
NOTIFICATION_SERVICE_URL=http://localhost:4002
WORKER_VERIFICATION_URL=http://localhost:4003