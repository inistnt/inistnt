# ═══════════════════════════════════════════════════════════
# INISTNT — Environment Variables
# Copy to .env — NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# ─── APP ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1
LOG_LEVEL=debug

# ─── DATABASE ──────────────────────────────────────────────
DATABASE_URL=postgresql://inistnt:inistnt_dev_password@localhost:5432/inistnt_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── REDIS ─────────────────────────────────────────────────
REDIS_URL=redis://:inistnt_redis_password@localhost:6379
REDIS_PREFIX=inistnt:

# ─── KAFKA ─────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=inistnt-api
KAFKA_GROUP_ID=inistnt-api-group

# ─── ELASTICSEARCH ─────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=inistnt_

# ─── CLICKHOUSE ────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=inistnt
CLICKHOUSE_PASSWORD=inistnt_ch_password
CLICKHOUSE_DATABASE=inistnt_analytics

# ─── S3 / MINIO ────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9003
S3_ACCESS_KEY=inistnt_minio_user
S3_SECRET_KEY=inistnt_minio_password
S3_BUCKET_DOCUMENTS=inistnt-documents
S3_BUCKET_PHOTOS=inistnt-photos
S3_BUCKET_BANNERS=inistnt-banners
S3_REGION=ap-south-1
S3_PUBLIC_URL=http://localhost:9003

# ─── JWT ───────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_to_random_256bit_string_in_production
JWT_REFRESH_SECRET=change_this_to_different_random_256bit_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── OTP ───────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_DEV_BYPASS=123456

# ─── SMS — MSG91 ───────────────────────────────────────────
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=INSTN
MSG91_TEMPLATE_ID_OTP=your_template_id

# ─── EMAIL — RESEND ────────────────────────────────────────
# Dev: emails console mein print honge (Mailhog optional)
# Prod: Resend use hoga
# Free tier: 3,000 emails/month — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Inistnt <noreply@inistnt.in>
EMAIL_FROM_NAME=Inistnt

# ─── SUPERADMIN ────────────────────────────────────────────
SUPER_ADMIN_EMAIL=superadmin@inistnt.com
SUPER_ADMIN_PASSWORD=InistntSuperAdmin@2026!
DEFAULT_STAFF_PASSWORD=Staff@Inistnt2026!

# ─── FIREBASE (FCM Push Notifications) ─────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# ─── RAZORPAY (Payment collection) ─────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── CASHFREE PAYOUTS (Worker disbursement) ────────────────
# Dashboard: https://merchant.cashfree.com → Payout → API Keys
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_ENV=TEST
# Prod ke liye: CASHFREE_ENV=PROD

# ─── GOOGLE MAPS ───────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_key

# ─── GROQ AI (Uniform Check + Face Match + Text Analysis) ──
# FREE — 30 req/min, 14,400 req/day
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxx
# Models used:
#   Vision: meta-llama/llama-4-scout-17b-16e-instruct
#   Text:   llama-3.3-70b-versatile

# ─── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── RATE LIMITING ─────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── INTERNAL SERVICE URLS ─────────────────────────────────
MATCHING_ENGINE_URL=http://localhost:4001
NOTIFICATION_SERVICE_URL=http://localhost:4003

# ─── WHATSAPP BUSINESS ─────────────────────────────────────────────
# Provider choice: msg91 (default) or interakt
WHATSAPP_PROVIDER=msg91

# MSG91 WhatsApp — https://msg91.com/whatsapp
MSG91_WHATSAPP_TOKEN=your_msg91_whatsapp_token
MSG91_WHATSAPP_SENDER=918888888888   # Your approved WhatsApp Business number

# Interakt — https://interakt.ai (alternative provider)
# INTERAKT_API_KEY=your_interakt_key
